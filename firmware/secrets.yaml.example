# Copy this file to firmware/secrets.yaml and fill in your values.
# secrets.yaml is gitignored and must never be committed.
#
# WiFi is configured via the captive portal after first flash — no credentials
# needed here unless you want to pre-configure a specific network.

# ESPHome API encryption key (base64-encoded 32 bytes).
# Generate a fresh key with:
#   python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "your_base64_api_key_here"

# OTA password — used by esphome OTA platform to authenticate update pushes.
# Must stay consistent across all firmware versions for OTA to keep working.
ota_password: "your_ota_password_here"
