# WiFi credentials
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Fallback AP password (min 8 characters)
fallback_ap_password: "FALLBACK_PASSWORD"

# ESPHome API encryption key (32 hex characters)
api_encryption_key: "01234567890123456789012345678901"

# OTA password
ota_password: "OTA_PASSWORD"
